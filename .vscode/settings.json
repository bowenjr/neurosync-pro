{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.activateEnvironment": true,
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["tests/unit"],
  "python.testing.unittestEnabled": false,

  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },

  "files.exclude": {
    "**/__pycache__": true,
    "**/.mypy_cache": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true
  },
  "search.exclude": {
    "**/.venv": true,
    "firmware/esp32/build": true,
    "firmware/esp32/managed_components": true,
    "measurements/raw": true,
    "**/__pycache__": true
  },
  "files.watcherExclude": {
    "**/.venv/**": true,
    "firmware/esp32/build/**": true,
    "firmware/esp32/managed_components/**": true
  },

  "idf.espIdfPath": "~/esp/esp-idf-current",
  "idf.customExtraPaths": "",
  "idf.pythonBinPath": "~/.espressif/python_env/idf5.5_py3.12_env/bin/python",

  "C_Cpp.default.compilerPath": ""
}
