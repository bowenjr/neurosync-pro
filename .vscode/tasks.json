    {
      "label": "test",
      "type": "shell",
      "command": "make test",
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "check (lint+typecheck+test)",
      "type": "shell",
      "command": "make check",
      "group": "test",
      "problemMatcher": []
    },
    {
