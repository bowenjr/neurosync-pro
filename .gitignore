# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# uv
# (uv.lock IS committed intentionally — do not ignore it)

# ESP-IDF / firmware build output
firmware/esp32/build/
firmware/esp32/build-*/
firmware/esp32/sdkconfig
firmware/esp32/managed_components/
firmware/esp32/dependencies.lock

# Secrets and local machine config — never committed
.env
*.env
!config/*.env.example
config/toolchain-lock.json.local

# Runtime / measurement data (bench captures are local artifacts, not source)
measurements/raw/*
!measurements/raw/.gitkeep
measurements/processed/*
!measurements/processed/.gitkeep

# Editor / OS
.DS_Store
*.swp

# VS Code local overrides (workspace-committed files are NOT ignored)
.vscode/*.local.json

# Backups created by this setup's scripts
*.bak.*
*.bak
firmware/esp32/sdkconfig.old
