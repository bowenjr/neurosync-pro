# Committed template for local hardware configuration.
# Copy the values you need into ~/.config/neurosync/hardware.env (uncommitted,
# machine-specific — see Phase 8 of docs/setup/SETUP-REPORT.md). Do not put
# secrets here; this file is committed to the repository.

NEUROSYNC_PI_HOST=neurosync-pi
NEUROSYNC_PI_HOSTNAME=neurosync-pi.local
NEUROSYNC_PI_USER=bowen
NEUROSYNC_PI_PATH=/home/bowen/apps/neurosync-pro
NEUROSYNC_ESP32_TARGET=esp32
NEUROSYNC_ESP32_PORT=auto
NEUROSYNC_ESP_IDF_PATH=auto
