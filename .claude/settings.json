{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(uv sync*)",
      "Bash(uv run ruff*)",
      "Bash(uv run mypy*)",
      "Bash(uv run pytest*)",
      "Bash(uv run neurosync*)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(pytest *)",
      "Bash(cmake *)",
      "Bash(ninja *)",
      "Bash(idf.py build*)",
      "Bash(idf.py --version*)",
      "Bash(idf.py set-target*)",
      "Bash(idf.py fullclean*)",
      "Bash(idf.py size*)",
      "Bash(shellcheck *)",
      "Bash(python3 -m json.tool*)",
      "Bash(scripts/doctor/*.sh*)",
      "Bash(scripts/esp32/detect.sh*)",
      "Bash(scripts/esp32/build.sh*)",
      "Bash(scripts/esp32/chip-info.sh*)",
      "Bash(scripts/esp32/monitor.sh*)",
      "Bash(scripts/pi/status.sh*)",
      "Bash(scripts/pi/inventory.sh)",
      "Bash(scripts/pi/test.sh*)",
      "Bash(scripts/pi/logs.sh*)",
      "Bash(make doctor*)",
      "Bash(make lint*)",
      "Bash(make typecheck*)",
      "Bash(make test*)",
      "Bash(make check*)",
      "Bash(make esp32-detect*)",
      "Bash(make esp32-build*)",
      "Bash(make esp32-chip-info*)",
      "Bash(make pi-status*)",
      "Bash(make pi-inventory)",
      "Bash(make pi-test*)",
      "Bash(make pi-logs*)"
    ],
    "ask": [
      "Bash(sudo *)",
      "Bash(apt *)",
      "Bash(apt-get *)",
      "Bash(usermod *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(ssh-copy-id *)",
      "Bash(rsync *)",
      "Bash(scripts/pi/bootstrap.sh*)",
      "Bash(scripts/pi/deploy.sh*)",
      "Bash(scripts/pi/inventory.sh --write-manifest*)",
      "Bash(scripts/pi/shell.sh*)",
      "Bash(scripts/pi/install-services.sh*)",
      "Bash(scripts/pi/remove-services.sh*)",
      "Bash(systemctl *)",
      "Bash(make pi-inventory-save*)",
      "Bash(idf.py flash*)",
      "Bash(idf.py *flash*)",
      "Bash(scripts/esp32/flash.sh*)",
      "Bash(scripts/esp32/flash-monitor.sh*)",
      "Bash(esptool*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git merge*)",
      "Write(~/.bashrc)",
      "Write(~/.ssh/*)",
      "Write(~/bin/*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rsync *--delete*)",
      "Bash(idf.py erase-flash*)",
      "Bash(idf.py *erase*)",
      "Bash(esptool*erase_flash*)",
      "Bash(esptool.py *erase_flash*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_ed25519*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets.*)"
    ],
    "defaultMode": "default"
  }
}
